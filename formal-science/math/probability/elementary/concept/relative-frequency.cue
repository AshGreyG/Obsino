package concept

relative_frequency: {
  content: #"""
    *Relative frequency* is the ratio of the frequency of an event to the total
    number of trials or observations. Relative frequency is a real number between
    $0$ and $1$, and the sum of relative frequencies over all possible events
    equals $1$:

    $ f_A = ("frequency of" A)/"total number of trails" = (n_A)/n $
  """#
  related: [
    "concept/absolute-frequency"
  ]
}