package concept

finite_union: {
  content: #"""
    A *finite union* is the union of a *finite number* of events $A_1, A_2, ⋯,
    A_n$ (where $n$ is a finite positive integer), its notation:

    $ ⋃_(i=1)^n A_i = A_1 ∪ A_2 ∪ ⋯ ∪ A_n $

    This is the event that at least one of $A_1, A_2, ⋯ A_n$ occurs.
  """#
  related: [
    "concept/union-of-events",
    "concept/countable-infinite-union"
  ]
}