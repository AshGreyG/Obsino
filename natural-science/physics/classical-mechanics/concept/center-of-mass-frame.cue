package concept

center_of_mass_frame: {
  content: #"""
    The *center-of-mass frame* is a special reference frame whose origin is fixed
    at the center of mass and moves with it. In this frame:

    - The position of the center of mass is zero $ub(x)'_"center" = ub(0)$;
    - The total momentum is zero: $ub(p)' = ∑ m_i ub(v)'_i = ub(0)$
  """#
  related: [
    "concept/center-of-mass"
  ]
}