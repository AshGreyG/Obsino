package law

impulse_momentum_theorem: {
  content: #"""
    *Impulse-Momentum Theorem*: the impulse of the net external force acting on
    a particle equals the change in its momentum:

    $ ub(J) = Δ ub(p) := ub(p)(t_2) - ub(p)(t_1) $

    Substituting the definitions:

    $ ∫_(t_1)^(t_2) ub(F) "d"t = m ub(v)(t_2) - m ub(v)(t_1) $
  """#
  related: [
    "concept/momentum",
    "concept/impulse",
    "proof/proof-impulse-momentum-theorem"
  ]
}