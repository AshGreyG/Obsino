package law

gay_lussac_law: {
  content: #"""
    For a fixed amount of gas kept at constant pressure, the volume and temperature
    are *directly proportional*:

    $ V_1/T_1 = V_2/T_2 = "constant" ("for fixed" p, n) $
  """#
  related: [
    "law/charles-law",
    "law/avogadro-law",
    "law/boyle-law"
  ]
}