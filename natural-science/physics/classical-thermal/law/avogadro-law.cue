package law

avogadro_law: {
  content: #"""
    For a fixed pressure of gas kept at constant temperature, the amount and
    volume are *directly proportional*:

    $ V_1/n_1 = V_2/n_2 = "constant" ("for fixed" T, P) $
  """#
  related: [
    "law/boyle-law",
    "law/charles-law",
    "law/gay-lussac-law"
  ]
}