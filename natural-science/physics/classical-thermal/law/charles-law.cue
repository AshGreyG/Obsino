package law

charles_law: {
  content: #"""
    For a fixed amount of gas kept at constant volume, the pressure and temperature
    are *directly proportional*:

    $ p_1/T_1 = p_2/T_2 = "constant" ("for fixed" n, V) $
  """#
  related: [
    "law/boyle-law",
    "law/avogadro-law",
    "law/gay-lussac-law"
  ]
}