package law

equipartition_theorem: {
  content: #"""
    *Equipartition Theorem* states that *for a system in thermal equilibrium at
    temperature $T$, the average energy associated with each quadratic degree of
    freedom is $1\/2 k T$*.

    If a kind of molecule has $i$ degrees of freedom then its total kinetic
    energy is $i\/2 k T$.
  """#
  related: [
    "concept/temperature-from-microscopic",
    "concept/degrees-of-freedom"
  ]
}