package concept

collision_cross_section: {
  content: #"""
    Imagine two molecules as hard spheres of diameter $d$. A collision occurs
    when the center-to-center distance becomes $≤ d$. The effective target area
    is a circle of radius $d$, hence area:

    $ σ = π d^2 $

    this area $σ$ is called the collision cross-section
  """#
}