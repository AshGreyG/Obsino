  solution    -.Metronidazole Rectal Perfusion Solution.-> rectal
  foam        -.Chlorhexidine Acetate Hemorrhoid Foam  .-> rectal
  tampon      -.Absorbable Hemostatic Rectal Tampon    .-> rectal

  %% Vaginal dosage forms
  pessary    -.Clotrimazole Pessaries                      .-> vaginal
  cream      -.Miconazole Nitrate Vaginal Cream            .-> vaginal
  gel        -.Recombinant Human Interferon α2b Vaginal Gel.-> vaginal
  film       -.Contraceptive Vaginal Film                  .-> vaginal
  ring       -.Contraceptive Vaginal Ring                  .-> vaginal
  solution   -.Vaginal Douche Solution                     .-> vaginal
  suspension -.Clotrimazole Vaginal Suspension             .-> vaginal
  emulsion   -.Estriol Vaginal Emulsion                    .-> vaginal
  foam       -.Tinidazole Vaginal Foam                     .-> vaginal
  tampon     -.Menstrual Tampon                            .-> vaginal

  %% Topical dosage foams
  ointment -.Mupriocin Ointment  .-> topical
  cream    -.Hydrocortisone Cream.-> topical